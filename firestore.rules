rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Default Deny All)
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global Security Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    // Validation Blueprint for Crop
    function isValidCrop(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.scientificName is string && data.scientificName.size() <= 200
        && data.origin is string && data.origin.size() <= 600
        && data.description is string && data.description.size() <= 3000
        && data.uses is string && data.uses.size() <= 1000
        && data.careLevel is string && data.careLevel.size() <= 50
        && data.sunlight is string && data.sunlight.size() <= 300
        && data.waterRequirements is string && data.waterRequirements.size() <= 300
        && data.harvestTime is string && data.harvestTime.size() <= 100
        && data.priceSol is number && data.priceSol >= 0
        && data.priceUsdc is number && data.priceUsdc >= 0
        && data.priceUsdt is number && data.priceUsdt >= 0
        && data.stock is int && data.stock >= 0
        && (data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 10000000))
        && data.scannedAt is string && data.scannedAt.size() <= 100
        && data.isForSale is bool;
    }
    
    // Validation Blueprint for SolanaTransaction
    function isValidTransaction(data) {
      return data.id is string && data.id.size() <= 128
        && data.signature is string && data.signature.size() <= 200
        && data.timestamp is string && data.timestamp.size() <= 100
        && data.buyerAddress is string && data.buyerAddress.size() <= 128
        && data.sellerAddress is string && data.sellerAddress.size() <= 128
        && data.cropId is string && data.cropId.size() <= 128
        && data.cropName is string && data.cropName.size() <= 200
        && data.quantity is int && data.quantity >= 1
        && data.tokenUsed is string && data.tokenUsed.size() <= 10
        && data.totalAmountPaid is number && data.totalAmountPaid >= 0
        && data.discountApplied is bool
        && data.status is string && data.status.size() <= 50;
    }
    
    // Crops Collection Rules
    match /crops/{cropId} {
      // Secure List / Document Fetching: Anybody can read public forSale crops, or users can read their own
      allow read: if (resource == null || resource.data.isForSale == true || (isSignedIn() && resource.data.userId == request.auth.uid));
      
      // Verification-enforced creation
      allow create: if (
        isSignedIn()
        && isEmailVerified()
        && isValidId(cropId)
        && incoming().userId == request.auth.uid
        && isValidCrop(incoming())
      );
      
      // Tiered Identity Logic:
      // Tier 1: The owner can modify the entire crop properties.
      // Tier 2: A buyer (non-owner) can only decrement the available stock on checkout, and nothing else.
      allow update: if (
        isSignedIn()
        && isEmailVerified()
        && isValidId(cropId)
        && (
          (existing().userId == request.auth.uid && incoming().userId == request.auth.uid && isValidCrop(incoming()))
          ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['stock']) && incoming().stock >= 0 && incoming().stock < existing().stock)
        )
      );
      
      // Deletion is strictly reserved to the owner
      allow delete: if (
        isSignedIn()
        && isEmailVerified()
        && isValidId(cropId)
        && existing().userId == request.auth.uid
      );
    }
    
    // Transaction logs (Solana Pay payees ledger)
    match /transactions/{transactionId} {
      // Secure Query Enforcer (Only buyer can pull logs)
      allow list, get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Auth and verification required on transaction submission
      allow create: if (
        isSignedIn()
        && isEmailVerified()
        && isValidId(transactionId)
        && incoming().userId == request.auth.uid
        && isValidTransaction(incoming())
      );
      
      // Transactions are read-only and immutable after creation
      allow update, delete: if false;
    }
  }
}

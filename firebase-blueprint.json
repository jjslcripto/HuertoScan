{
  "entities": {
    "Crop": {
      "title": "Crop",
      "description": "Represents an organic crop identified by botanical scanning and available for sale in the community market.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier of the crop." },
        "name": { "type": "string", "description": "The common name of the crop." },
        "scientificName": { "type": "string", "description": "The botanical scientific name." },
        "origin": { "type": "string", "description": "The geographic origin of the crop." },
        "description": { "type": "string", "description": "Detailed description of the plant." },
        "uses": { "type": "string", "description": "Common uses and benefits of the plant." },
        "careLevel": { "type": "string", "description": "Fácil, Moderado, Difícil care difficulty." },
        "sunlight": { "type": "string", "description": "Sunlight requirements." },
        "waterRequirements": { "type": "string", "description": "Watering suggestions." },
        "harvestTime": { "type": "string", "description": "Time until harvest." },
        "recommendedPriceSol": { "type": "number", "description": "Recommended price in SOL." },
        "recommendedPriceUsdc": { "type": "number", "description": "Recommended price in USDC." },
        "recommendedPriceUsdt": { "type": "number", "description": "Recommended price in USDT." },
        "priceSol": { "type": "number", "description": "User-set price in SOL." },
        "priceUsdc": { "type": "number", "description": "User-set price in USDC." },
        "priceUsdt": { "type": "number", "description": "User-set price in USDT." },
        "stock": { "type": "integer", "description": "Available stock quantity." },
        "imageUrl": { "type": "string", "description": "Optional image URL." },
        "scannedAt": { "type": "string", "description": "ISO timestamp when scanned." },
        "isForSale": { "type": "boolean", "description": "Whether the crop is currently for sale." },
        "notes": { "type": "string", "description": "Optional notes from the cultivator." },
        "userId": { "type": "string", "description": "Firebase Auth user ID of the owner." },
        "frutas": { "type": "string" },
        "frutos": { "type": "string" },
        "hojas": { "type": "string" },
        "clorofila": { "type": "string" },
        "raiz": { "type": "string" },
        "tallo": { "type": "string" },
        "flor": { "type": "string" },
        "semilla": { "type": "string" },
        "savia": { "type": "string" },
        "estomas": { "type": "string" }
      },
      "required": ["id", "name", "scientificName", "origin", "description", "uses", "careLevel", "sunlight", "waterRequirements", "harvestTime", "priceSol", "priceUsdc", "priceUsdt", "stock", "scannedAt", "isForSale"]
    },
    "SolanaTransaction": {
      "title": "SolanaTransaction",
      "description": "Represents a confirmed Solana Pay transaction within the community market.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The transaction identifier." },
        "signature": { "type": "string", "description": "The blockchain signature." },
        "timestamp": { "type": "string", "format": "date-time" },
        "buyerAddress": { "type": "string" },
        "sellerAddress": { "type": "string" },
        "cropId": { "type": "string" },
        "cropName": { "type": "string" },
        "quantity": { "type": "integer" },
        "tokenUsed": { "type": "string", "enum": ["SOL", "USDC", "USDT"] },
        "totalAmountPaid": { "type": "number" },
        "discountApplied": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pending", "processing", "confirming", "success", "failed"] },
        "userId": { "type": "string", "description": "The buyer's authenticated Firebase Auth user ID, if any." }
      },
      "required": ["id", "signature", "timestamp", "buyerAddress", "sellerAddress", "cropId", "cropName", "quantity", "tokenUsed", "totalAmountPaid", "discountApplied", "status"]
    }
  },
  "firestore": {
    "crops/{cropId}": {
      "schema": "Crop",
      "description": "The root crops collection containing all custom-created or presets of crops for community garden."
    },
    "transactions/{transactionId}": {
      "schema": "SolanaTransaction",
      "description": "Ledger of confirmed purchases and payments on Solana Pay."
    }
  }
}

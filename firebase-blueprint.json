        "id": {
          "type": "string",
          "description": "ID unico del cultivo"
        },
        "name": {
          "type": "string",
          "description": "Nombre de la planta"
        },
        "scientificName": {
          "type": "string",
          "description": "Nombre cientifico"
        },

        "recommendedPriceSol",
        "recommendedPriceUsdc",
        "recommendedPriceUsdt",
        "priceSol",
        "priceUsdc",
        "priceUsdt",
        "stock",
        "scannedAt",
        "isForSale",
        "userId",
        "frutas",
